# Plane webhook secret generated when the webhook is created.
PLANE_WEBHOOK_SECRET=replace-with-plane-webhook-secret

# Telegram bot token from BotFather.
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token

# Telegram chat ID, group ID, or channel ID.
TELEGRAM_CHAT_ID=replace-with-telegram-chat-id

# Optional: only notify when issue assignee email/name matches this value.
# PLANE_USER_EMAIL=you@example.com

# Optional: max X-Plane-Delivery IDs kept in memory for retry dedupe.
DELIVERY_CACHE_LIMIT=1000

# Optional: file path for local task state.
STATE_FILE=data/state.json

# Optional: HTTP server port. Railway sets this automatically.
PORT=3000
